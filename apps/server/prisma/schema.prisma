// filepath: apps/server/prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
  EMPLOYEE
}

enum AccountStatus {
  PENDING
  ACTIVE
  REJECTED
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum LoyaltyTier {
  BRONZE // 0-499 pts
  SILVER // 500-1499 pts
  GOLD // 1500+ pts
}

enum TransactionType {
  EARN
  REDEEM
  MANUAL_ADJUST
}

enum DiscountType {
  PERCENTAGE
  AMOUNT
  OTHER
}

enum CouponStatus {
  ACTIVE
  USED
}

enum RescheduleStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CancellationRequestStatus {
  PENDING
  APPROVED
  REJECTED
  WITHDRAWN
}

enum TreatmentSeriesStatus {
  ACTIVE
  COMPLETED
}

enum TreatmentSeriesNotificationKind {
  BEFORE_DUE
  DUE
  OVERDUE
}

enum HappyHourType {
  ONE_TIME
  RECURRING
}

enum StorePromotionEventType {
  VIEW
  CLICK
  COPY_CODE
  SAVE
  UNSAVE
  REMINDER_SET
}

enum FinanceRevenueSource {
  SERVICE
  PRODUCT
  VOUCHER
  OTHER
}

enum FinanceCostCategory {
  PRODUCTS
  MARKETING
  RENT
  SALARIES
  UTILITIES
  TAXES
  EQUIPMENT
  TRAINING
  SOFTWARE
  OTHER
}

enum FinancePaymentMethod {
  CASH
  CARD
  TRANSFER
  BLIK
  OTHER
}

enum FinanceSalesChannel {
  WALK_IN
  BOOKING
  WEBSITE
  INSTAGRAM
  FACEBOOK
  PHONE
  REFERRAL
  OTHER
}

enum FinanceEntryStatus {
  PAID
  UNPAID
  PARTIAL
  REFUNDED
}

enum InventoryMovementType {
  PURCHASE
  USAGE
  SALE
  WASTE
  CORRECTION
}

enum SkinType {
  SUCHA
  TLUSTA
  MIESZANA
  NORMALNA
  WRAZLIWA
}

enum Difficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum LessonType {
  VIDEO
  TEXT
  QUIZ
}

enum VideoProvider {
  YOUTUBE
  VIMEO
}

enum QuestionType {
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  TRUE_FALSE
}

enum AccessAction {
  GRANTED
  REVOKED
  EXTENDED
  EXPIRED
}

model User {
  id                     String        @id @default(cuid())
  email                  String        @unique
  passwordHash           String?
  googleId               String?       @unique
  facebookId             String?       @unique
  emailVerificationToken String?       @unique
  name                   String
  phone                  String?
  role                   Role          @default(USER)
  avatarPath             String?
  loyaltyPoints          Int           @default(0)
  loyaltyTier            LoyaltyTier   @default(BRONZE)
  resetToken             String?
  resetTokenExp          DateTime?
  passwordChangedAt      DateTime?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
  hasAcademyAccess       Boolean       @default(false)
  academyAccessExpiresAt DateTime?
  academyGrantedById     String?
  academyGrantedAt       DateTime?
  termsAcceptedAt        DateTime?
  marketingConsent       Boolean       @default(false)
  photoConsent           Boolean       @default(false)
  onboardingCompleted    Boolean       @default(false)
  accountStatus          AccountStatus @default(PENDING)
  mustChangePassword     Boolean       @default(false)

  cardAllergies   String?
  cardConditions  String?
  cardPreferences String?
  cardStaffNotes  String?

  ambassadorCode String? @unique
  referredById   String?
  referredBy     User?   @relation("Referrals", fields: [referredById], references: [id])
  referrals      User[]  @relation("Referrals")
  referralCount  Int     @default(0)

  appointments                Appointment[]
  loyaltyTransactions         LoyaltyTransaction[]
  coupons                     UserCoupon[]
  sentMessages                ChatMessage[]                    @relation("SentMessages")
  receivedMessages            ChatMessage[]                    @relation("ReceivedMessages")
  chatRoom                    ChatRoom?                        @relation("UserChatRoom")
  adminChatRooms              ChatRoom[]                       @relation("AdminChatRooms")
  blogPosts                   BlogPost[]
  blogComments                BlogComment[]                    @relation("BlogCommentAuthor")
  blogCommentReactions        BlogCommentReaction[]            @relation("BlogCommentReactions")
  employee                    Employee?
  lockedDiscountCodes         DiscountCode[]                   @relation("LockedDiscountCodes")
  discountCodeUsages          DiscountCodeUsage[]              @relation("DiscountCodeUsages")
  pushSubscriptions           PushSubscription[]
  reviews                     Review[]
  achievements                UserAchievement[]
  serviceReminders            ServiceReminder[]
  treatmentSeries             TreatmentSeries[]
  notifications               Notification[]
  appointmentRecommendations  AppointmentRecommendation[]
  addedRecommendations        AppointmentRecommendation[]      @relation("RecommendationAddedBy")
  createdStorePromotions      StorePromotion[]                 @relation("StorePromotionCreatedBy")
  storePromotionFavorites     StorePromotionFavorite[]
  storePromotionReminders     StorePromotionReminder[]
  storePromotionEvents        StorePromotionEvent[]
  skinJournalEntries          SkinJournalEntry[]
  journalEntriesAuthored      SkinJournalEntry[]               @relation("JournalEntryAuthor")
  journalComments             SkinJournalComment[]
  blogPostLikes               BlogPostLike[]
  skinWeatherProfile          SkinWeatherProfile?
  skinWeatherReports          SkinWeatherReport[]
  academyAccessLogs           AcademyAccessLog[]
  refreshTokens               RefreshToken[]
  passkeys                    Passkey[]
  beautyPlans                 BeautyPlan[]                     @relation("UserBeautyPlans")
  createdBeautyPlans          BeautyPlan[]                     @relation("BeautyPlanCreatedBy")
  forumThreads                ForumThread[]                    @relation("ForumThreadAuthor")
  forumPosts                  ForumPost[]                      @relation("ForumPostAuthor")
  forumWatches                ForumWatch[]                     @relation("ForumWatchUser")
  forumReactions              ForumReaction[]                  @relation("ForumReactionUser")
  createdVouchers             Voucher[]                        @relation("VoucherCreatedBy")
  financeRevenueEntries       FinanceRevenue[]                 @relation("FinanceRevenueUser")
  cancellationRequests        AppointmentCancellationRequest[] @relation("CancellationRequestUser")
  decidedCancellationRequests AppointmentCancellationRequest[] @relation("CancellationRequestDecider")

  @@index([role])
}

enum AcademyOrderStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  CANCELLED
}

model RefreshToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model Passkey {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentialId String    @unique
  publicKey    String
  counter      Int       @default(0)
  deviceName   String?
  transports   String[]
  createdAt    DateTime  @default(now())
  lastUsedAt   DateTime?

  @@index([userId])
}

model WebAuthnChallenge {
  id        String   @id @default(cuid())
  challenge String   @unique
  userId    String?
  purpose   String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId, purpose])
  @@index([expiresAt])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
}

model Service {
  id                      String         @id @default(cuid())
  name                    String
  slug                    String         @unique
  description             String
  price                   Decimal        @db.Decimal(10, 2)
  durationMinutes         Int
  category                String
  displayOrder            Int            @unique @default(1)
  imagePath               String?
  isActive                Boolean        @default(true)
  detailedContent         String?
  recommendedIntervalDays Int?
  isMultiVisit            Boolean        @default(false)
  seriesIntervalsDays     Int[]          @default([])
  seasons                 Season[]       @default([])
  routineFirst48h         String?
  routineFollowingDays    String?
  routineProducts         String?
  promoDiscountType       DiscountType?
  promoDiscountValue      Decimal?       @db.Decimal(10, 2)
  promoStartDate          DateTime?
  promoEndDate            DateTime?
  promoMaxUses            Int?
  locationId              String?
  location                SalonLocation? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt

  appointments          Appointment[]
  metamorphoses         Metamorphosis[]
  loyaltyRewards        LoyaltyReward[]        @relation("RewardServices")
  employees             Employee[]             @relation("ServiceEmployees")
  quizResults           QuizResult[]
  quizSuggestions       QuizResultSuggestion[]
  reviews               Review[]
  treatmentSeries       TreatmentSeries[]
  happyHours            HappyHour[]            @relation("HappyHourServices")
  recommendedSlides     RecommendedSlide[]
  vouchers              Voucher[]              @relation("VoucherService")
  financeRevenueEntries FinanceRevenue[]

  @@index([category])
  @@index([isActive])
  @@index([locationId])
}

model BlogPost {
  id              String         @id @default(cuid())
  title           String
  slug            String         @unique
  content         String // TipTap JSON serialized
  excerpt         String
  coverImage      String?
  isPublished     Boolean        @default(false)
  views           Int            @default(0)
  readingTime     Int?
  metaTitle       String?
  metaDescription String?
  category        String?
  authorId        String
  author          User           @relation(fields: [authorId], references: [id])
  tags            Tag[]          @relation("PostTags")
  comments        BlogComment[]
  likes           BlogPostLike[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([isPublished])
  @@index([category])
  @@index([authorId])
}

model BlogPostLike {
  id        String   @id @default(cuid())
  postId    String
  post      BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([postId, userId])
  @@index([postId])
}

model Tag {
  id    String     @id @default(cuid())
  name  String     @unique
  slug  String     @unique
  posts BlogPost[] @relation("PostTags")
}

model BlogComment {
  id        String        @id @default(cuid())
  postId    String
  post      BlogPost      @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User          @relation("BlogCommentAuthor", fields: [authorId], references: [id], onDelete: Restrict)
  parentId  String?
  parent    BlogComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  replies   BlogComment[] @relation("CommentReplies")
  content   String
  imagePath String?
  isHidden  Boolean       @default(false)
  isSpam    Boolean       @default(false)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  reactions BlogCommentReaction[]

  @@index([postId])
  @@index([parentId])
}

model BlogCommentReaction {
  id        String      @id @default(cuid())
  commentId String
  comment   BlogComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  userId    String
  user      User        @relation("BlogCommentReactions", fields: [userId], references: [id], onDelete: Cascade)
  emoji     String
  createdAt DateTime    @default(now())

  @@unique([commentId, userId])
  @@index([commentId])
}

model Metamorphosis {
  id          String   @id @default(cuid())
  title       String
  description String?
  beforeImage String
  afterImage  String
  serviceId   String?
  service     Service? @relation(fields: [serviceId], references: [id])
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model LoyaltyReward {
  id          String   @id @default(cuid())
  name        String
  description String
  pointsCost  Int
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  requiredTier       LoyaltyTier?
  isForAllServices   Boolean      @default(true)
  applicableServices Service[]    @relation("RewardServices")

  discountType  DiscountType @default(AMOUNT)
  discountValue Decimal?     @db.Decimal(10, 2)

  redemptions LoyaltyTransaction[]
  userCoupons UserCoupon[]
}

model LoyaltyTransaction {
  id          String          @id @default(cuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id])
  points      Int
  type        TransactionType
  description String
  rewardId    String?
  reward      LoyaltyReward?  @relation(fields: [rewardId], references: [id])
  createdAt   DateTime        @default(now())

  @@index([userId, createdAt])
}

model UserCoupon {
  id            String        @id @default(cuid())
  code          String?       @unique
  userId        String
  user          User          @relation(fields: [userId], references: [id])
  rewardId      String
  reward        LoyaltyReward @relation(fields: [rewardId], references: [id])
  status        CouponStatus  @default(ACTIVE)
  activatedAt   DateTime      @default(now())
  usedAt        DateTime?
  appointmentId String?       @unique
  appointment   Appointment?  @relation(fields: [appointmentId], references: [id])
}

model Employee {
  id          String   @id @default(cuid())
  name        String
  bio         String?
  avatarPath  String?
  specialties String[]
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id])

  appointments   Appointment[]
  workDays       EmployeeWorkDay[]
  weeklySchedule EmployeeWeeklySchedule[]
  services       Service[]                @relation("ServiceEmployees")
  happyHours     HappyHour[]              @relation("HappyHourEmployees")
}

model EmployeeWorkDay {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date       DateTime // stored as midnight UTC for that day
  timeBlocks Json? // [{ start: "09:00", end: "13:00" }]
  isWorking  Boolean  @default(true)
  note       String?
  createdAt  DateTime @default(now())

  @@unique([employeeId, date])
}

model EmployeeWeeklySchedule {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  dayOfWeek  Int // 0=Mon, 1=Tue, 2=Wed, 3=Thu, 4=Fri, 5=Sat, 6=Sun
  isWorking  Boolean  @default(true)
  timeBlocks Json // [{ start: "09:00", end: "13:00" }]
  updatedAt  DateTime @updatedAt

  @@unique([employeeId, dayOfWeek])
}

model Appointment {
  id                         String            @id @default(cuid())
  userId                     String?
  user                       User?             @relation(fields: [userId], references: [id])
  clientName                 String?
  clientPhone                String?
  clientEmail                String?
  customDurationMinutes      Int?
  serviceId                  String
  service                    Service           @relation(fields: [serviceId], references: [id])
  employeeId                 String?
  employee                   Employee?         @relation(fields: [employeeId], references: [id])
  date                       DateTime
  status                     AppointmentStatus @default(PENDING)
  priceAtBooking             Decimal           @db.Decimal(10, 2)
  finalPrice                 Decimal           @db.Decimal(10, 2)
  discountTotal              Decimal           @default(0) @db.Decimal(10, 2)
  discountBreakdown          Json              @default("[]")
  loyaltyPointsAwarded       Int?
  locationId                 String?
  location                   SalonLocation?    @relation(fields: [locationId], references: [id], onDelete: SetNull)
  locationNameAtBooking      String?
  locationAddressAtBooking   String?
  locationLatitudeAtBooking  Decimal?          @db.Decimal(9, 6)
  locationLongitudeAtBooking Decimal?          @db.Decimal(9, 6)
  salonPhoneAtBooking        String?
  notes                      String?
  allergies                  String?
  problemDescription         String?
  photoPath                  String?
  staffNote                  String?
  completedAt                DateTime?
  treatmentSeriesId          String?
  treatmentSeries            TreatmentSeries?  @relation(fields: [treatmentSeriesId], references: [id], onDelete: SetNull)
  treatmentSeriesStep        Int?
  createdAt                  DateTime          @default(now())
  updatedAt                  DateTime          @updatedAt

  coupon                UserCoupon?
  discountCodeUsage     DiscountCodeUsage?
  review                Review?
  recommendations       AppointmentRecommendation[]
  homecareRoutine       HomecareRoutine?
  journalEntries        SkinJournalEntry[]
  cancellationRequests  AppointmentCancellationRequest[]
  financeRevenueEntries FinanceRevenue[]

  happyHourId String?
  happyHour   HappyHour? @relation(fields: [happyHourId], references: [id], onDelete: SetNull)

  rescheduleDate   DateTime?
  rescheduleStatus RescheduleStatus?

  @@index([treatmentSeriesId])
  @@index([userId])
  @@index([userId, status])
  @@index([date])
  @@index([employeeId])
  @@index([locationId])
}

model AppointmentCancellationRequest {
  id                String                    @id @default(cuid())
  appointmentId     String
  appointment       Appointment               @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  userId            String
  user              User                      @relation("CancellationRequestUser", fields: [userId], references: [id], onDelete: Cascade)
  status            CancellationRequestStatus @default(PENDING)
  reason            String?
  policyNoticeHours Int
  policyVersion     String
  decidedById       String?
  decidedBy         User?                     @relation("CancellationRequestDecider", fields: [decidedById], references: [id], onDelete: SetNull)
  decisionNote      String?
  decidedAt         DateTime?
  withdrawnAt       DateTime?
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  @@index([appointmentId, status])
  @@index([userId, status])
}

model DiscountCode {
  id             String              @id @default(cuid())
  code           String              @unique
  discountType   DiscountType
  discountValue  Decimal             @db.Decimal(10, 2)
  isActive       Boolean             @default(true)
  isMultiUse     Boolean             @default(false)
  lockedToUserId String?
  lockedToUser   User?               @relation("LockedDiscountCodes", fields: [lockedToUserId], references: [id])
  usages         DiscountCodeUsage[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  expiresAt      DateTime?
  voucher        Voucher?            @relation("VoucherDiscountCode")
}

model DiscountCodeUsage {
  id             String       @id @default(cuid())
  discountCodeId String
  discountCode   DiscountCode @relation(fields: [discountCodeId], references: [id])
  userId         String
  user           User         @relation("DiscountCodeUsages", fields: [userId], references: [id])
  appointmentId  String?      @unique
  appointment    Appointment? @relation(fields: [appointmentId], references: [id])
  usedAt         DateTime     @default(now())

  @@unique([discountCodeId, userId])
}

model AmbassadorConfig {
  id                    String       @id @default(cuid())
  discountType          DiscountType @default(PERCENTAGE)
  discountValue         Decimal      @default(10) @db.Decimal(10, 2)
  referrerDiscountType  DiscountType @default(PERCENTAGE)
  referrerDiscountValue Decimal      @default(10) @db.Decimal(10, 2)
  updatedAt             DateTime     @updatedAt
}

model SalonTerms {
  id                      String   @id @default(cuid())
  content                 String
  version                 String   @default("1.0")
  cancellationNoticeHours Int      @default(24)
  updatedAt               DateTime @updatedAt
}

model SalonLocation {
  id           String        @id @default(cuid())
  name         String
  street       String
  postalCode   String
  city         String
  latitude     Decimal?      @db.Decimal(9, 6)
  longitude    Decimal?      @db.Decimal(9, 6)
  phone        String?
  email        String?
  isDefault    Boolean       @default(false)
  isActive     Boolean       @default(true)
  services     Service[]
  appointments Appointment[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([isDefault, isActive])
}

model HeroSlide {
  id           String   @id @default(cuid())
  imagePath    String
  title        String?
  heading      String?
  subtitle     String?
  textPosition String?  @default("middle-center")
  fontStyle    String?  @default("heading")
  buttons      Json?
  order        Int      @default(0)
  isMain       Boolean  @default(false)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
}

model RecommendedSlide {
  id          String   @id @default(cuid())
  serviceId   String
  service     Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  description String
  imagePath   String
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
}

model StorePromotion {
  id                 String                   @id @default(cuid())
  storeName          String
  brand              String?
  category           String?
  title              String
  description        String
  conditions         String                   @default("")
  discountValue      String
  promoCode          String?
  link               String?
  imageUrl           String?
  tags               String[]                 @default([])
  targetLoyaltyTiers LoyaltyTier[]            @default([])
  targetSkinTypes    SkinType[]               @default([])
  targetConcerns     String[]                 @default([])
  startDate          DateTime
  endDate            DateTime
  isActive           Boolean                  @default(true)
  isFeatured         Boolean                  @default(false)
  viewCount          Int                      @default(0)
  clickCount         Int                      @default(0)
  copyCount          Int                      @default(0)
  saveCount          Int                      @default(0)
  createdById        String?
  createdBy          User?                    @relation("StorePromotionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  favorites          StorePromotionFavorite[]
  reminders          StorePromotionReminder[]
  events             StorePromotionEvent[]
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt

  @@index([isActive, startDate, endDate])
  @@index([isFeatured])
  @@index([category])
  @@index([createdById])
}

model StorePromotionFavorite {
  id          String         @id @default(cuid())
  promotionId String
  promotion   StorePromotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime       @default(now())

  @@unique([promotionId, userId])
  @@index([userId, createdAt])
}

model StorePromotionReminder {
  id          String         @id @default(cuid())
  promotionId String
  promotion   StorePromotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  remindAt    DateTime
  sentAt      DateTime?
  createdAt   DateTime       @default(now())

  @@unique([promotionId, userId])
  @@index([userId, remindAt])
  @@index([sentAt])
}

model StorePromotionEvent {
  id          String                  @id @default(cuid())
  promotionId String
  promotion   StorePromotion          @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?                   @relation(fields: [userId], references: [id], onDelete: SetNull)
  type        StorePromotionEventType
  createdAt   DateTime                @default(now())

  @@index([promotionId, type, createdAt])
  @@index([userId, createdAt])
}

model AboutPage {
  id               String   @id @default(cuid())
  salonTagline     String   @default("")
  salonDescription String   @default("")
  salonCoverImage  String?
  ownerName        String   @default("Wiktoria Ćwik")
  ownerTitle       String   @default("Właścicielka & Kosmetolożka")
  ownerBio         String   @default("")
  ownerPhoto       String?
  featuresTitle    String   @default("Dlaczego warto wybrać Cosmo?")
  features         Json     @default("[]")
  appDescription   String   @default("")
  updatedAt        DateTime @updatedAt
}

model ConsultationLead {
  id             String    @id @default(cuid())
  name           String
  email          String
  phone          String
  consentContact Boolean   @default(false)
  consentData    Boolean   @default(false)
  contacted      Boolean   @default(false)
  archived       Boolean   @default(false)
  contactedAt    DateTime?
  notes          String?
  createdAt      DateTime  @default(now())
}

model ChatRoom {
  id            String        @id @default(cuid())
  userId        String        @unique
  user          User          @relation("UserChatRoom", fields: [userId], references: [id])
  adminId       String?
  admin         User?         @relation("AdminChatRooms", fields: [adminId], references: [id])
  lastMessageAt DateTime      @default(now())
  userUnread    Int           @default(0)
