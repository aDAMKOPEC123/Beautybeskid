model Course {
  id                 String       @id @default(cuid())
  title              String
  slug               String       @unique
  description        String
  status             CourseStatus @default(DRAFT)
  thumbnailUrl       String?
  difficulty         Difficulty   @default(BEGINNER)
  estimatedMinutes   Int          @default(0)
  price              Decimal      @default(0) @db.Decimal(10, 2)
  tags               String[]     @default([])
  isActive           Boolean      @default(true)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  modules            CourseModule[]
  progress           UserCourseProgress[]
  certificates       AcademyCertificate[]
  favorites          CourseFavorite[]
  enrollments        AcademyEnrollment[]
}

model AcademyUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  googleId     String?  @unique
  name         String
  role         Role     @default(USER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  refreshTokens      AcademyRefreshToken[]
  enrollments        AcademyEnrollment[]
  academyProgress    UserCourseProgress[]
  academyLessonProgress UserLessonProgress[]
  academyCertificates AcademyCertificate[]
  academyQuizAttempts AcademyQuizAttempt[]
  courseFavorites     CourseFavorite[]
  lessonNotes         LessonNote[]
  academySupportThread AcademySupportThread? @relation("AcademySupportUser")
  academySupportAssignments AcademySupportThread[] @relation("AcademySupportAdmin")
  academySupportMessages AcademySupportMessage[] @relation("AcademySupportAuthor")

  @@index([role])
}

model AcademyRefreshToken {
  id        String      @id @default(cuid())
  tokenHash String      @unique
  userId    String
  user      AcademyUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime    @default(now())

  @@index([userId])
}

model AcademyEnrollment {
  id        String      @id @default(cuid())
  userId    String
  user      AcademyUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId  String
  course    Course      @relation(fields: [courseId], references: [id], onDelete: Cascade)
  purchasedAt DateTime  @default(now())
  createdAt DateTime    @default(now())

  @@unique([userId, courseId])
  @@index([userId])
}

model CourseModule {
  id       String   @id @default(cuid())
  courseId String
  course   Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title    String
  order    Int      @default(0)

  lessons  Lesson[]

  @@index([courseId])
}

model Lesson {
  id               String         @id @default(cuid())
  moduleId         String
  module           CourseModule   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  title            String
  slug             String
  type             LessonType
  videoProvider    VideoProvider?
  videoId          String?
  contentHtml      String?
  thumbnailUrl     String?
  estimatedMinutes Int            @default(0)
  order            Int            @default(0)
  isRequired       Boolean        @default(true)

  progress         UserLessonProgress[]
  quiz             AcademyQuiz?
  notes            LessonNote[]

  @@unique([moduleId, slug])
  @@index([moduleId])
}

model AcademyQuiz {
  id                 String   @id @default(cuid())
  lessonId           String?  @unique
  lesson             Lesson?  @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  title              String
  description        String?
  thumbnailUrl       String?
  passingScore       Int      @default(70)
  maxAttempts        Int      @default(3)
  timeLimitMinutes   Int?
  isPublished        Boolean  @default(false)
  createdAt          DateTime @default(now())

  questions          AcademyQuizQuestion[]
  attempts           AcademyQuizAttempt[]
  certificates       AcademyCertificate[]
}

model AcademyQuizQuestion {
  id          String       @id @default(cuid())
  quizId      String
  quiz        AcademyQuiz  @relation(fields: [quizId], references: [id], onDelete: Cascade)
  text        String
  type        QuestionType @default(SINGLE_CHOICE)
  order       Int          @default(0)
  explanation String?

  options     AcademyQuizOption[]

  @@index([quizId])
}

model AcademyQuizOption {
  id         String              @id @default(cuid())
  questionId String
  question   AcademyQuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  text       String
  isCorrect  Boolean             @default(false)
  order      Int                 @default(0)

  @@index([questionId])
}

model AcademyQuizAttempt {
  id          String      @id @default(cuid())
  userId      String
  user        AcademyUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  quizId      String
  quiz        AcademyQuiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
  score       Int
  passed      Boolean
  answers     Json
  startedAt   DateTime    @default(now())
  completedAt DateTime?

  @@index([userId, quizId])
}

model UserCourseProgress {
  id              String   @id @default(cuid())
  userId          String
  user            AcademyUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId        String
  course          Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  percentComplete Float    @default(0)
  startedAt       DateTime @default(now())
  completedAt     DateTime?

  @@unique([userId, courseId])
  @@index([userId])
}

model UserLessonProgress {
  id             String   @id @default(cuid())
  userId         String
  user           AcademyUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId       String
  lesson         Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  watchedSeconds Int      @default(0)
  completed      Boolean  @default(false)
  completedAt    DateTime?

  @@unique([userId, lessonId])
  @@index([userId])
}

model AcademyCertificate {
  id               String       @id @default(cuid())
  userId           String
  user             AcademyUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId         String?
  course           Course?      @relation(fields: [courseId], references: [id], onDelete: SetNull)
  quizId           String?
  quiz             AcademyQuiz? @relation(fields: [quizId], references: [id], onDelete: SetNull)
  verificationCode String       @unique
  issuedAt         DateTime     @default(now())

  @@index([userId])
  @@index([verificationCode])
}

model CourseFavorite {
  id        String   @id @default(cuid())
  userId    String
  user      AcademyUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, courseId])
}

model LessonNote {
  id             String   @id @default(cuid())
  userId         String
  user           AcademyUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId       String
  lesson         Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  content        String
  videoTimestamp Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId, lessonId])
}

model AcademyAccessLog {
  id        String       @id @default(cuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  adminId   String
  action    AccessAction
  expiresAt DateTime?
  createdAt DateTime     @default(now())

  @@index([userId])
}

model AcademySupportThread {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          AcademyUser @relation("AcademySupportUser", fields: [userId], references: [id], onDelete: Cascade)
  adminId       String?
  admin         AcademyUser? @relation("AcademySupportAdmin", fields: [adminId], references: [id], onDelete: SetNull)
  lastMessageAt DateTime @default(now())
  userUnread    Int      @default(0)
  adminUnread   Int      @default(0)
  messages      AcademySupportMessage[]
  createdAt     DateTime @default(now())
}

model AcademySupportMessage {
  id        String               @id @default(cuid())
  threadId  String
  thread    AcademySupportThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
