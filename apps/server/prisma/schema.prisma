  createdAt   DateTime      @default(now())

  @@index([order])
}

model ForumThread {
  id          String        @id @default(cuid())
  title       String
  content     String
  isAnonymous Boolean       @default(false)
  isPinned    Boolean       @default(false)
  isLocked    Boolean       @default(false)
  isDeleted   Boolean       @default(false)
  viewCount   Int           @default(0)
  tags        String[]
  authorId    String
  author      User          @relation("ForumThreadAuthor", fields: [authorId], references: [id])
  categoryId  String
  category    ForumCategory @relation(fields: [categoryId], references: [id])
  posts       ForumPost[]
  watches     ForumWatch[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([categoryId])
  @@index([isDeleted])
  @@index([authorId])
}

model ForumPost {
  id            String      @id @default(cuid())
  content       String
  isAnonymous   Boolean     @default(false)
  isDeleted     Boolean     @default(false)
  mentionsAdmin Boolean     @default(false)
  quotedPostId   String?
  quotedContent  String?
  reactions      ForumReaction[]
  authorId      String
  author        User        @relation("ForumPostAuthor", fields: [authorId], references: [id])
  threadId      String
  thread        ForumThread @relation(fields: [threadId], references: [id])
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([threadId])
  @@index([isDeleted])
  @@index([authorId])
}

model ForumWatch {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation("ForumWatchUser", fields: [userId], references: [id])
  threadId  String
  thread    ForumThread @relation(fields: [threadId], references: [id])
  createdAt DateTime    @default(now())

  @@index([threadId])
  @@unique([userId, threadId])
}

enum ReactionType {
  LIKE
  HEART
  HELPFUL
}

model ForumReaction {
  id        String       @id @default(cuid())
  userId    String
  postId    String
  type      ReactionType
  createdAt DateTime     @default(now())
  user      User         @relation("ForumReactionUser", fields: [userId], references: [id], onDelete: Cascade)
  post      ForumPost    @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId, type])
  @@index([postId])
}

enum VoucherType {
  SERVICE
  CASH
}

model Voucher {
  id             String        @id @default(cuid())
  type           VoucherType
  recipientName  String?
  senderName     String?
  message        String?
  serviceId      String?
  service        Service?      @relation("VoucherService", fields: [serviceId], references: [id])
  amount          Decimal?      @db.Decimal(10, 2)
  remainingAmount Decimal?      @db.Decimal(10, 2)
  discountCodeId String?       @unique
  discountCode   DiscountCode? @relation("VoucherDiscountCode", fields: [discountCodeId], references: [id], onDelete: Restrict)
  code           String        @unique
  validUntil     DateTime
  pdfPath        String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  createdById    String?
  createdBy      User?         @relation("VoucherCreatedBy", fields: [createdById], references: [id])
}
